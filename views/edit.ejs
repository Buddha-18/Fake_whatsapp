<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Your Chat</title>
</head>
<body>
    <p>Edit Your Chat: <%= chat._id %></p>
    <p>This chat was sent from <i><%= chat.from %></i> to <i><%= chat.to %></i></p>

    <form method="post" action="/chats/<%= chat._id %>?_method=PUT">
        <textarea name="msg" rows="6" cols="50"><%= chat.msg %></textarea><br>
        <button>Edit</button>
    </form>
</body>
</html>